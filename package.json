{
  "name": "rocket-rogue-poc",
  "version": "0.1.0",
  "private": true,
  "author": "Rocket Rogue Team",
  "license": "UNLICENSED",
  "description": "C++20 native Vulkan 1.3 and WebGL2 rocket-launch roguelite.",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "sanity": "node tools/sanity-check.mjs",
    "doctor": "node tools/verify-toolchain.mjs",
    "prepare:azure": "node tools/prepare-azure-static-web-app.mjs",
    "serve:web": "node tools/serve.mjs build/web-release 8080",
    "configure:native": "node tools/run-cmake-preset.mjs configure native-debug",
    "build:native": "node tools/run-cmake-preset.mjs build native-debug",
    "test:native": "node tools/run-cmake-preset.mjs test native-debug",
    "configure:native:release": "node tools/run-cmake-preset.mjs configure native-release",
    "build:native:release": "node tools/run-cmake-preset.mjs build native-release",
    "test:native:release": "node tools/run-cmake-preset.mjs test native-release",
    "configure:native:profile": "node tools/run-cmake-preset.mjs configure native-profile",
    "build:native:profile": "node tools/run-cmake-preset.mjs build native-profile",
    "test:native:profile": "node tools/run-cmake-preset.mjs test native-profile",
    "package:native": "node tools/run-cmake-preset.mjs build package-native",
    "shaders:vulkan": "node tools/build-vulkan-shaders.mjs",
    "check:shaders:vulkan": "node tools/build-vulkan-shaders.mjs --check",
    "summarize:benchmarks": "node tools/summarize-native-benchmarks.mjs",
    "configure:web": "node tools/run-cmake-preset.mjs configure web-release",
    "build:web": "node tools/run-cmake-preset.mjs build web-release",
    "test:web": "node tools/run-web-tests.mjs"
  }
}
